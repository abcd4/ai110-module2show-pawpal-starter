classDiagram
    class Owner {
        +str name
        +list~Pet~ pets
        +list~tuple~ availability
    }

    class Pet {
        +int id
        +str name
        +str breed
        +int age
        +list~str~ medications
        +list~Task~ tasks
        +add_task(task Task) void
        +remove_task(task Task) void
    }

    class Task {
        +str category
        +int priority
        +int duration
        +Pet pet
        +bool done
        +mark_complete() void
    }

    class Scheduler {
        +Owner owner
        +add_pet(pet Pet) void
        +remove_pet(pet Pet) void
        +get_daily_tasks() list~tuple~
    }

    Owner "1" --> "*" Pet : owns
    Scheduler "1" --> "1" Owner : belongs to
    Pet "1" --> "*" Task : has
